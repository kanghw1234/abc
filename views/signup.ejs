<!DOCTYPE html>
<html lang="ko">
<head>
    <meta charset="UTF-8">
    <title>Signup - Steam Clone</title>
    <link rel="stylesheet" href="/style.css">
</head>
<body>
    <div class="container" style="max-width: 400px; margin-top: 100px; text-align: center;">
        <h2>회원가입</h2>
        <form action="/signup" method="POST">
            <input type="text" name="username" placeholder="아이디" required>
            <input type="password" name="password" placeholder="비밀번호" required>
            <input type="text" name="nickname" placeholder="닉네임" required>
            <button type="submit" style="width: 100%;">가입 완료</button>
        </form>
        <p style="margin-top: 20px; font-size: 13px;">
            이미 계정이 있나요? <a href="/login" style="color: #66c0f4;">로그인</a>
        </p>
    </div>
</body>
</html>
