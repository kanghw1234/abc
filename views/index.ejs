<!DOCTYPE html>
<html lang="ko">
<head>
    <meta charset="UTF-8">
    <title>Steam Clone - Home</title>
    <link rel="stylesheet" href="/style.css">
</head>
<body>
    <header>
        <div class="logo"><a href="/">STEAM MASTER</a></div>
        <nav>
            <% if (user) { %>
                <span><b><%= user.nickname %></b>님 안녕하세요</span>
                <a href="/logout">로그아웃</a>
            <% } else { %>
                <a href="/login">로그인</a>
                <a href="/signup">회원가입</a>
            <% } %>
        </nav>
    </header>

    <div class="container">
        <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 20px;">
            <h2>게임 상점 목록</h2>
            <form action="/" method="GET" style="display: flex; gap: 5px;">
                <input type="text" name="search" placeholder="검색어 입력" value="<%= search %>" style="width: 200px; margin: 0;">
                <button type="submit" style="padding: 5px 15px;">검색</button>
            </form>
        </div>

        <table>
            <thead>
                <tr>
                    <th>게임 이름</th>
                    <th>별점 (5점)</th>
                    <th>출시일시</th>
                </tr>
            </thead>
            <tbody>
                <% games.forEach(game => { %>
                    <tr onclick="location.href='/game/<%= game.id %>'">
                        <td class="game-title"><%= game.title %></td>
                        <td class="rating">★ <%= parseFloat(game.avg_rating).toFixed(1) %></td>
                        <td class="date"><%= new Date(game.release_date).toLocaleString() %></td>
                    </tr>
                <% }); %>
            </tbody>
        </table>

        <div class="pagination">
            <% for(let i=1; i<=totalPages; i++) { %>
                <a href="/?page=<%= i %>&search=<%= search %>" class="<%= page === i ? 'active' : '' %>"><%= i %></a>
            <% } %>
        </div>
    </div>
</body>
</html>
