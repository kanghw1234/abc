<!DOCTYPE html>
<html lang="ko">
<head>
    <meta charset="UTF-8">
    <title><%= game.title %> - Steam Clone</title>
    <link rel="stylesheet" href="/style.css">
</head>
<body>
    <header>
        <div class="logo"><a href="/">STEAM_CLONE</a></div>
        <nav><a href="/">목록으로</a> <a href="/logout">로그아웃</a></nav>
    </header>

    <div class="container">
        <h1 style="color: #fff; margin-bottom: 5px;"><%= game.title %></h1>
        <p style="color: #66c0f4; font-size: 14px;">출시일: <%= new Date(game.release_date).toLocaleString() %></p>
        
        <div style="background: #2a475e; padding: 20px; margin: 20px 0; line-height: 1.8;">
            <h3>게임 소개</h3>
            <p><%= game.description %></p>
        </div>

        <hr style="border: 0; border-top: 1px solid #333; margin: 40px 0;">

        <h3>사용자 평가 및 리뷰</h3>

        <% if (!hasReviewed) { %>
            <div style="background: #171a21; padding: 20px; margin-bottom: 30px;">
                <h4>리뷰 남기기</h4>
                <form action="/game/<%= game.id %>/review" method="POST">
                    <select name="score" style="background: #2a475e; color: #fff; padding: 10px; margin-bottom: 10px; width: 100%;">
                        <option value="5">★★★★★ (매우 만족)</option>
                        <option value="4">★★★★☆ (만족)</option>
                        <option value="3">★★★☆☆ (보통)</option>
                        <option value="2">★★☆☆☆ (불만족)</option>
                        <option value="1">★☆☆☆☆ (매우 불만족)</option>
                    </select>
                    <textarea name="content" rows="4" placeholder="리뷰 내용을 작성해 주세요..." required></textarea>
                    <button type="submit">평가 등록</button>
                </form>
            </div>
        <% } %>

        <div class="review-list">
            <% reviews.forEach(review => { %>
                <div class="review-card">
                    <div style="display: flex; justify-content: space-between;">
                        <span style="color: #fff; font-weight: bold;"><%= review.nickname %></span>
                        <span style="color: #f1c40f;"><%= "★".repeat(review.score) %></span>
                    </div>
                    <div style="font-size: 12px; color: #66c0f4; margin: 5px 0;">
                        플레이 시간: <%= review.play_time %>시간 | 작성일: <%= new Date(review.created_at).toLocaleDateString() %>
                    </div>
                    <p style="margin-top: 10px;"><%= review.content %></p>
                </div>
            <% }); %>
            <% if (reviews.length === 0) { %>
                <p style="color: #b8b6b4;">아직 리뷰가 없습니다. 첫 리뷰를 작성해 보세요!</p>
            <% } %>
        </div>
    </div>
</body>
</html>
